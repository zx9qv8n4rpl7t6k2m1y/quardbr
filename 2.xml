<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<title>IAmQuadrober</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/createzalma6z/quardbr@main/style.css"/>
<style>
  canvas:focus{outline:none;}
  html,body{padding:0;margin:0;overflow:hidden;overscroll-behavior:none;height:100%;
    -webkit-touch-callout:none;-webkit-user-select:none;-moz-user-select:none;
    -ms-user-select:none;user-select:none;-webkit-tap-highlight-color:rgba(0,0,0,0);}
</style>
</head>
<body class="dark">
<div id="unity-container" class="unity-desktop">
  <canvas id="unity-canvas" tabindex="-1"></canvas>
</div>
<div id="loading-cover" style="display:none;">
  <div id="unity-loading-bar">
    <div id="unity-logo"><img src="https://cdn.jsdelivr.net/gh/createzalma6z/seyya774@main/logo.png" onerror="this.style.display='none'"/></div>
    <div id="unity-progress-bar-empty" style="display:none;">
      <div id="unity-progress-bar-full"></div>
    </div>
    <div class="spinner"></div>
  </div>
</div>

<script>
window.YaGames = { init: function() {
  var sdk = {
    environment: { app:{id:'0'}, i18n:{lang:'en',tld:'com'}, browser:{lang:'en'}, payload:null },
    deviceInfo: { type:'desktop',
      isMobile:  function(){ return false; },
      isDesktop: function(){ return true;  },
      isTablet:  function(){ return false; },
      isTV:      function(){ return false; }
    },
    adv: {
      showFullscreenAdv: function(o){ if(o&&o.callbacks&&o.callbacks.onClose) o.callbacks.onClose(false); },
      showRewardedVideo: function(o){
        if(!o||!o.callbacks) return;
        if(o.callbacks.onOpen)     o.callbacks.onOpen();
        if(o.callbacks.onRewarded) o.callbacks.onRewarded();
        if(o.callbacks.onClose)    o.callbacks.onClose();
      },
      showBannerAdv:function(){},hideBannerAdv:function(){},
      getBannerAdvStatus:function(){ return Promise.resolve({stickyAdvIsShowing:false}); }
    },
    auth:{ openAuthDialog:function(){ return Promise.resolve(); } },
    feedback:{
      canReview:function(){ return Promise.resolve({value:false,reason:''}); },
      requestReview:function(){ return Promise.resolve({feedbackSent:false}); }
    },
    shortcut:{
      canShowPrompt:function(){ return Promise.resolve({canShow:false}); },
      showPrompt:function(){ return Promise.resolve({outcome:'rejected'}); }
    },
    getPayments:function(){ return Promise.reject('no payments'); },
    getPlayer:function(){ return Promise.resolve({
      isAuthorized:function(){return false;},getMode:function(){return 'lite';},
      getName:function(){return '';},getUniqueID:function(){return '0';},
      getPhoto:function(){return '';},getPayingStatus:function(){return 'unknown';},
      setData:function(){return Promise.resolve();},getData:function(){return Promise.resolve({});}
    });},
    getFlags:function(){ return Promise.resolve({}); },
    serverTime:function(){ return Promise.resolve(Date.now()); },
    on:function(){},
    features:{
      LoadingAPI:{ready:function(){}},
      GameplayAPI:{start:function(){},stop:function(){}}
    }
  };
  return Promise.resolve(sdk);
}};
</script>
<script>
(function(){ var s=document.createElement('script'); s.src='/sdk.js';
  s.onerror=function(){console.warn('[Stub] sdk.js yuklenemedi');}; document.head.appendChild(s); })();

/* AudioContext unlock */
(function(){
  function unlockAudio(){
    if(window._audioUnlocked) return; window._audioUnlocked=true;
    try{
      var ctx=new(window.AudioContext||window.webkitAudioContext)();
      var b=ctx.createBuffer(1,1,22050); var s=ctx.createBufferSource();
      s.buffer=b; s.connect(ctx.destination); s.start(0); ctx.resume&&ctx.resume();
    }catch(e){}
    document.removeEventListener('touchstart',unlockAudio);
    document.removeEventListener('pointerdown',unlockAudio);
    document.removeEventListener('click',unlockAudio);
  }
  document.addEventListener('touchstart',  unlockAudio, {passive:true});
  document.addEventListener('pointerdown', unlockAudio, {passive:true});
  document.addEventListener('click',       unlockAudio, {passive:true});
})();
</script>

<script>
var CDN        = "https://cdn.jsdelivr.net/gh/createzalma6z/quardbr@5bd5a66/Build";   /* <-- degistir */
var DATA_PARTS = 5;   /* 35.7MB / 8MB = 5 part */
var WASM_PARTS = 5;   /* 34.9MB / 8MB = 5 part */

var buildUrl = CDN;
var config = {
  dataUrl:            null,
  frameworkUrl:       buildUrl + "/IAmQuadrober.framework.js",
  codeUrl:            null,
  streamingAssetsUrl: "StreamingAssets",
  companyName:        "JustAlien",
  productName:        "IAmQuadrober",
  productVersion:     "1.0"
};

var container        = document.querySelector("#unity-container");
var canvas           = document.querySelector("#unity-canvas");
var loadingCover     = document.querySelector("#loading-cover");
var progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
var progressBarFull  = document.querySelector("#unity-progress-bar-full");
var spinner          = document.querySelector('.spinner');

if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent))
  container.className = "unity-mobile";

loadingCover.style.display = "";

var NO_DATA = 'no data';
var StartUnityInstance;
var ygGameInstance = null;
var ysdk = null;
var initYSDK = false;
var initGame = false;
var syncInit = false;
var isVisibility = true;
var isPausedGame = false;
var nowFullAdOpen = false;
var environmentData = NO_DATA;

document.addEventListener('contextmenu', function(e){ e.preventDefault(); });
document.addEventListener('visibilitychange', function(){ SetVisibility(!document.hidden); });
window.addEventListener('blur',  function(){ SetVisibility(false); });
window.addEventListener('focus', function(){ SetVisibility(true); });
window.addEventListener('pointerdown', function(){ FocusGame(); SetVisibility(true); });
window.addEventListener('resize', function(){ FocusGame(); });
document.addEventListener('fullscreenchange', function(){ FocusGame(); });

var oRPL = Element.prototype.requestPointerLock;
Element.prototype.requestPointerLock = async function() {
  var args = Array.from(arguments);
  try { (args[0]=args[0]||{}).unadjustedMovement=true; await oRPL.apply(this,args); } catch(e){ console.log(e); }
};

function InstallBlurFocusBlocker(){
  if(!('onblur' in document)||window.blurFocusHandlersInstalled) return;
  window.addEventListener('blur', function(){
    var btn=document.createElement('button');
    Object.assign(btn.style,{position:'fixed',top:'0',left:'0',width:'100%',height:'100%',
      zIndex:'9999',backgroundColor:'rgba(0,0,0,0)',border:'none',cursor:'default'});
    document.body.appendChild(btn);
    window.addEventListener('focus', function rem(){
      btn.parentNode&&btn.parentNode.removeChild(btn);
      window.removeEventListener('focus',rem);
    });
  });
  window.blurFocusHandlersInstalled=true;
}

function FocusGame(checkingPauseStatus){
  if(checkingPauseStatus===undefined) checkingPauseStatus=true;
  if(!canvas) return;
  requestAnimationFrame(function(){
    if(checkingPauseStatus&&isPausedGame) return;
    canvas.focus({preventScroll:true});
  });
}
function SetVisibility(v){
  if(ysdk!==null&&initGame===true&&isVisibility!==v){
    isVisibility=v; YG2Instance('SetFocusWindowGame',v?'true':'false');
  }
}
function PauseCallback(){  isPausedGame=true;  YG2Instance('SetPauseGame','true'); }
function ResumeCallback(){ isPausedGame=false; YG2Instance('SetPauseGame','false'); FocusGame(false); }

async function fetchParts(baseUrl, partCount){
  var parts=[];
  for(var i=0;i<partCount;i++){
    var r=await fetch(baseUrl+'.part'+i);
    if(!r.ok) throw new Error('part'+i+': HTTP '+r.status);
    parts.push(new Uint8Array(await r.arrayBuffer()));
  }
  var total=parts.reduce(function(s,p){return s+p.length;},0);
  var merged=new Uint8Array(total); var off=0;
  for(var j=0;j<parts.length;j++){merged.set(parts[j],off);off+=parts[j].length;}
  return merged;
}
function brotliBlobUrl(uint8,filename){
  var blob=new Blob([uint8],{type:'application/octet-stream'});
  return URL.createObjectURL(blob)+'#'+encodeURIComponent(filename);
}

var script=document.createElement("script");
script.src=buildUrl+"/IAmQuadrober.loader.js";
script.onload=async function(){
  try{
    var dataBytes=await fetchParts(buildUrl+"/IAmQuadrober.data.br", DATA_PARTS);
    var wasmBytes=await fetchParts(buildUrl+"/IAmQuadrober.wasm.br", WASM_PARTS);
    config.dataUrl = brotliBlobUrl(dataBytes,"IAmQuadrober.data.br");
    config.codeUrl = brotliBlobUrl(wasmBytes,"IAmQuadrober.wasm.br");
  }catch(e){ alert("Download error: "+e.message); return; }

  StartUnityInstance=function(){
    createUnityInstance(canvas,config,function(progress){
      spinner.style.display="none";
      progressBarEmpty.style.display="";
      progressBarFull.style.width=(100*Math.max(progress,0.05))+'%';
    }).then(function(inst){
      ygGameInstance=inst;
      loadingCover.style.background="";
      loadingCover.style.display="none";
      FocusGame();
    }).catch(function(msg){console.error(msg);});
  };

  InstallBlurFocusBlocker();
  InitYSDK();
  StartUnityInstance_IfUnloaded();
};

function StartUnityInstance_IfUnloaded(){
  if(typeof StartUnityInstance==='function'&&spinner.style.display!=="none")
    StartUnityInstance();
}
function IsLocalHost(){
  try{
    if(window.top!==window) return false;
    var h=window.location.hostname;
    return h==="localhost"||h==="127.0.0.1"||h.endsWith(".local");
  }catch(e){return false;}
}
function YG2Instance(method,arg){
  if(ygGameInstance==null) return;
  var send=function(){
    arg!==undefined
      ?ygGameInstance.SendMessage('YG2Instance',method,arg)
      :ygGameInstance.SendMessage('YG2Instance',method);
  };
  if(!initGame) setTimeout(send,100); else send();
}
function LogStyledMessage(msg){
  console.log('%c'+msg,'color:#FFDF73;background-color:#454545');
}

async function InitYSDK(){
  try{
    if(IsLocalHost()) return;
    ysdk=await YaGames.init();
    ysdk.on('game_api_pause',PauseCallback);
    ysdk.on('game_api_resume',ResumeCallback);
    await RequestingEnvironmentData(); LogStyledMessage('Init EnvirData ysdk');
    initYSDK=true;
    if(ygGameInstance!=null) ygGameInstance.SendMessage('YG2Instance','InitSDKComplete');
    LogStyledMessage('Init YandexSDK Success');
  }catch(e){console.error('CRASH Init SDK:',e);}
  if(!IsLocalHost()&&!syncInit) StartUnityInstance_IfUnloaded();
}

function InitGame(){
  initGame=true;
  setTimeout(function(){if(isPausedGame) YG2Instance('SetPauseGame','true');},100);
}
LogStyledMessage('[PluginYG2 v2.009] [Build: 1] [Platform: YandexGames]');

function RewardedAdvShow(id){
  try{
    ysdk.adv.showRewardedVideo({callbacks:{
      onOpen:     function(){LogStyledMessage('Opened Rewarded Adv');YG2Instance('OpenRewardedAdv');},
      onClose:    function(){LogStyledMessage('Closed Rewarded Adv'); YG2Instance('CloseRewardedAdv');FocusGame();},
      onRewarded: function(){YG2Instance('RewardAdv',id);},
      onError:    function(err){console.error(err);YG2Instance('ErrorRewardedAdv');}
    }});
  }catch(err){console.error('CRASH Rewarded:',err.message);}
}

function InterAdvShow(){
  try{
    if(!ysdk){LogStyledMessage('Cancel InterAdvShow: SDK not initialized');return;}
    if(nowFullAdOpen){LogStyledMessage('Cancel InterAdvShow: already open');return;}
    ysdk.adv.showFullscreenAdv({callbacks:{
      onOpen:  function(){LogStyledMessage('Open Interstitial Adv');nowFullAdOpen=true;if(initGame)YG2Instance('OpenInterAdv');},
      onClose: function(was){LogStyledMessage('Close Interstitial Adv');nowFullAdOpen=false;if(initGame)YG2Instance('CloseInterAdv',was?'true':'false');FocusGame();},
      onError: function(e){console.error(e);nowFullAdOpen=false;YG2Instance('ErrorInterAdv');FocusGame();}
    }});
  }catch(e){console.error('CRASH InterAdv:',e.message);}
}

function RequestingEnvironmentData(){
  return new Promise(function(resolve){
    if(!ysdk){Final(NO_DATA);return;}
    try{
      var ua=navigator.userAgent,browser;
      if(ua.includes('YaBrowser')||ua.includes('YaSearchBrowser')) browser='Yandex';
      else if(ua.includes('Opera')||ua.includes('OPR')) browser='Opera';
      else if(ua.includes('Firefox')) browser='Firefox';
      else if(ua.includes('MSIE')) browser='IE';
      else if(ua.includes('Edge')) browser='Edge';
      else if(ua.includes('Chrome')) browser='Chrome';
      else if(ua.includes('Safari')) browser='Safari';
      else browser='Other';
      Final(JSON.stringify({
        language:ysdk.environment.i18n.lang, domain:ysdk.environment.i18n.tld,
        deviceType:ysdk.deviceInfo.type, isMobile:ysdk.deviceInfo.isMobile(),
        isDesktop:ysdk.deviceInfo.isDesktop(), isTablet:ysdk.deviceInfo.isTablet(),
        isTV:ysdk.deviceInfo.isTV(), appID:ysdk.environment.app.id,
        browserLang:ysdk.environment.browser.lang, payload:ysdk.environment.payload,
        platform:navigator.platform, browser:browser
      }));
    }catch(e){console.error(e);Final(NO_DATA);}
    function Final(r){environmentData=r;YG2Instance('SetEnvirData',r);resolve(r);}
  });
}

document.body.appendChild(script);
</script>
</body>
</html>



